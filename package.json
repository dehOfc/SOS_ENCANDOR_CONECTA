{
  "name": "sos-encanador-conecta",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "concurrently \"npm --workspace @sos/api run dev\" \"npm --workspace @sos/web run dev\"",
    "api": "npm --workspace @sos/api run dev",
    "start": "npm --workspace @sos/api run start",
    "build": "npm --workspace @sos/web run build && npm --workspace @sos/api run build",
    "install-all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
